{
  "name": "xpendit-rules-engine",
  "version": "1.0.0",
  "description": "Xpendit expense rules engine",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "demo:rates": "tsx examples/validate-with-live-rates.ts",
    "analyze": "tsx src/batch/analyze.ts"
  },
  "dependencies": {
    "csv-parse": "^5.6.0",
    "decimal.js": "^10.5.0",
    "dotenv": "^16.5.0",
    "zod": "^3.25.67"
  },
  "keywords": ["xpendit", "expense", "rules-engine"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@vitest/coverage-v8": "^3.1.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
